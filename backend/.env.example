PORT=4000
NODE_ENV=development

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MongoDB
MONGO_URI=

# JWT (min 32 chars for production)
JWT_SECRET=change-me-in-production-min-32-chars

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION=false

# Tavily
TAVILY_API_KEY=

# CORS (comma-separated list of allowed origins)
CORS_ORIGIN=
